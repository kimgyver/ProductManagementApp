{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ecommerce;Username=postgres;Password=postgres"
  },
  "Email": {
    "ResendApiKey": "YOUR_RESEND_API_KEY",
    "FromAddress": "noreply@yourdomain.com"
  },
  "Jwt": {
    "Issuer": "YourIssuer",
    "Audience": "YourAudience",
    "Secret": "your_really_long_super_secure_secret_key_32_chars"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173,http://localhost:4173"
  },
  "AWS": {
    "Region": "ap-southeast-2",
    "Profile": "default",
    "SQSQueueUrl": "https://sqs.ap-southeast-2.amazonaws.com/840297437975/SendEmailQueue"
  },
  "AllowedHosts": "*"
}
